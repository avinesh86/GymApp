{
  "name": "Staff",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Full name of the staff member"
    },
    "email": {
      "type": "string",
      "description": "Email address"
    },
    "phone": {
      "type": "string",
      "description": "Phone number"
    },
    "role": {
      "type": "string",
      "enum": [
        "owner",
        "admin",
        "gym_manager",
        "payroll",
        "team_leader",
        "instructor",
        "class_count_admin"
      ],
      "default": "instructor",
      "description": "Staff role in the system"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "inactive"
      ],
      "default": "active"
    },
    "site": {
      "type": "string",
      "description": "Primary site/branch"
    },
    "qualifications": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "classes_can_teach": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "default_pay_rate_type": {
      "type": "string",
      "enum": [
        "per_class",
        "per_head",
        "blended"
      ],
      "default": "per_class"
    },
    "base_rate": {
      "type": "number"
    },
    "per_head_rate": {
      "type": "number"
    },
    "pay_rate_overrides": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "class_type_id": {
            "type": "string"
          },
          "class_type_name": {
            "type": "string"
          },
          "rate_type": {
            "type": "string",
            "enum": [
              "per_class",
              "per_head",
              "blended"
            ]
          },
          "rate": {
            "type": "number"
          }
        }
      }
    },
    "availability_preferences": {
      "type": "object",
      "properties": {
        "monday": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tuesday": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "wednesday": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "thursday": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "friday": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "saturday": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "sunday": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "priority_tier": {
      "type": "number",
      "default": 2
    },
    "cover_reliability_score": {
      "type": "number",
      "default": 100
    },
    "profile_image_url": {
      "type": "string"
    },
    "user_id": {
      "type": "string"
    },
    "business_name": {
      "type": "string",
      "description": "Business/trading name for invoices"
    },
    "business_logo_url": {
      "type": "string",
      "description": "Logo URL for invoices"
    },
    "payment_info": {
      "type": "object",
      "description": "Payment details shown on invoices",
      "properties": {
        "bank_name": {
          "type": "string"
        },
        "account_name": {
          "type": "string"
        },
        "account_number": {
          "type": "string"
        },
        "sort_code": {
          "type": "string"
        },
        "payment_reference": {
          "type": "string"
        },
        "additional_info": {
          "type": "string"
        }
      }
    }
  },
  "required": [
    "name",
    "email",
    "role"
  ]
}